# Nested install must NOT pull react / react-dom into src/app/playground/node_modules.
# They are peerDependencies provided by the host; keeping them out of the nested tree
# lets every playground import resolve UP to the host's single React copy (no duplicate
# React / "invalid hook call"). legacy-peer-deps disables npm 7+ transitive-peer auto-install.
legacy-peer-deps=true
